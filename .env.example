# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database / Cache ---
DATABASE_URL=postgresql://digichat:digichat@localhost:5432/digichat?schema=public
REDIS_URL=redis://localhost:6379

# --- JWT (gerar com: openssl rand -base64 32) ---
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-base64-32
JWT_REFRESH_SECRET=replace-me-with-openssl-rand-base64-32

# --- Cifragem (gerar com: openssl rand -hex 32) ---
CHANNEL_CONFIG_ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32-which-is-64-hex-chars-aaaaaaaa

# --- Storage (MinIO local) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=digichat-media

# --- Workers ---
AUTO_CLOSE_WORKER_INTERVAL_MINUTES=15
TEMPLATE_SYNC_CRON=0 3 * * *
WEBHOOK_DELIVERY_MAX_RETRIES=5

# --- Observabilidade (opcional em dev) ---
SENTRY_DSN=

# --- Seed do SUPER_ADMIN inicial (apenas dev — em produção, definir senha forte) ---
SEED_SUPER_ADMIN_EMAIL=super@digichat.local
SEED_SUPER_ADMIN_PASSWORD=changeme-only-for-dev
