{
  "name": "crm-api",
  "version": "0.0.1",
  "description": "DigiChat CRM API — NestJS 11 + Fastify + Zod + Prisma",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "lefthook install",
    "build": "nest build",
    "format": "prettier --write --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "g:feature": "nest g --collection ./schematics/collection.json feature",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "test:schema": "vitest run -c vitest.schema.config.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@swc/core",
      "bcrypt",
      "lefthook",
      "prisma"
    ]
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@prisma/client": "^6.19.3",
    "@scalar/nestjs-api-reference": "^1.1.12",
    "bcrypt": "^5.1.1",
    "fastify": "^5.8.5",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.3.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.9",
    "@angular-devkit/schematics": "^21.2.9",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/core": "^1.15.32",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.6",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.5"
  }
}
